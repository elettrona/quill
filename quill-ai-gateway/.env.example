# Copy this file to `.env` for local development ONLY (run.py loads it via
# python-dotenv). In production, set these through your host's real secret
# mechanism -- an environment file outside any git-tracked directory, or a
# managed secret store -- never by committing a filled-in .env anywhere.
#
# See docs/planning/openai.md §6 for the full secret-management plan.

# --- Required ---------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE-ME
GATEWAY_SECRET_KEY=REPLACE-ME-run-python-c-import-secrets-print-secrets-token-hex-32

# --- Storage -----------------------------------------------------------------
DATABASE_URL=postgresql://quill_gateway:REPLACE-ME@localhost:5432/quill_ai_gateway
REDIS_URL=redis://localhost:6379/0

# --- Admin access --------------------------------------------------------------
# Comma-separated device_ids permitted to reach /admin/* routes. Leave empty
# during initial setup, register your own device via the normal device-code
# flow, then add that device's id here and restart.
GATEWAY_ADMIN_ALLOWLIST=

# --- Public-facing --------------------------------------------------------------
GATEWAY_PUBLIC_BASE_URL=https://gateway.quillforall.org

# --- Optional -------------------------------------------------------------------
GATEWAY_OPENAI_MODEL=gpt-5-nano
GATEWAY_ALERT_WEBHOOK_URL=
