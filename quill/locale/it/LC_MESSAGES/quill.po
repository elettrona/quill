#: quill/ui/audio_studio/pages_start.py:19
msgid "Welcome to the Audio Studio"
msgstr "Ti do il benvenuto in Audio Studio"

#: quill/ui/audio_studio/pages_start.py:20
msgid "Choose what to make; the next steps adapt to your choice."
msgstr "Scegli cosa creare; i passi successivi si adattano alla tua scelta."

#: quill/ui/audio_studio/pages_start.py:24
msgid "What would you like to make?"
msgstr "Cosa vorresti creare?"

#: quill/ui/audio_studio/pages_start.py:26
msgid "Narrate documents into an audiobook or speech audio"
msgstr "Leggi ad alta voce i documenti in un audiolibro o file vocale"

#: quill/ui/audio_studio/pages_start.py:27
msgid "Combine audio files into one chaptered audiobook"
msgstr "Combina i file audio in un audiolibro diviso in capitoli."

#: quill/ui/audio_studio/pages_start.py:28
msgid "Edit an existing audiobook (chapters, tags, and cover)"
msgstr "Modifica un audiolibro esistente (capitoli, tag, e copertina)."

#: quill/ui/audio_studio/pages_start.py:48
msgid ""
"Narrating documents reads Word, Markdown, HTML, or text files\n"
"aloud with any QUILL voice, one chapter per document or heading.\n"
"Combining audio files merges a folder of recordings into one\n"
"book, one chapter per file, with a review step before the merge.\n"
"Editing opens a finished MP3 or M4B in the Chapter Workbench:\n"
"listen, rename, split at the playhead, retime, fix tags, save."
msgstr ""
"La narrazione di documenti legge ad alta voce file Word, Markdown, HTML o"
" di testo\n"
"con qualsiasi voce QUILL, un capitolo per documento o per intestazione.\n"
"La combinazione di file audio unisce una cartella di registrazioni in un "
"unico\n"
"libro, un capitolo per file, con una fase di revisione prima dell'unione."
"\n"
"La modifica apre un MP3 o M4B finito nel Chapter Workbench:\n"
"ascolta, rinomina, suddividi alla testina di riproduzione, regola i "
"tempi, correggi i tag, salva."

