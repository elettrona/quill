.ruff_cache/
.venv/
*.pyc
build/

# Generated build-identity module (regenerated by tools/generate_build_info.py)
quill/_build_info.py
# Generated bundled feedback token (regenerated by tools/generate_feedback_token.py)
quill/_feedback_token.py
# Generated offline-edition marker (regenerated by build_windows_distribution.py)
quill/_offline_edition.py
dist/
windows-distribution/
windows-distribution-offline/
windows-distribution-smoke/
# Versioned distribution build output (e.g. windows-distribution-0.8.0/).
windows-distribution-*/
release-artifacts/
release-dist-*/
release-artifacts-*/
installer-smoke*/
# Whisper model download cache (populated at runtime/build time).
.whisper-dl/

# Local working files (scratch notes, profiling output, one-off logs)
/local/
/dev.md

*.log
.quill-reqs.sha256
kokoro/_hf_cache/

tmp/
mypy_out.txt

# Coverage data and scratch commit-message files
.coverage
.coverage.*
msg.txt

# Editor local history (VS Code Local History extension)
.history/

# Data folder contents (folder tracked, contents ignored)
/data/*

# Working / scratch files (not part of the project)
zfix*
zkey*
key.md
key_fix_*.md
key_troubleshoot*.md
zquill_*.md
fix.md
email.md
/Status
keys.txt
/files/
docs/leasey.md
list.ps1
list.txt

# Generated epub/html renders of root-level and .github markdown (local only)
/*.epub
/*.html
.github/**/*.epub
.github/**/*.html
examples/**/*.epub
examples/**/*.html
gen.ps1

# liblouis build workspace (run scripts/build_braille_pack.py to regenerate)
/liblouis/

# Claude Code local state (jobs, worktrees, memory)
.claude/

# Bootstrapper binaries (downloaded at release build time by scripts/fetch_bootstrappers.py)
quill/_vendor/autoupdate/bootstrappers/bootstrap.exe
quill/_vendor/autoupdate/bootstrappers/bootstrap-lin.sh
quill/_vendor/autoupdate/bootstrappers/bootstrap-mac.sh
quill/_vendor/autoupdate/bootstrappers/bootstrap.pb

# Local sample corpus for batch document-to-speech testing/debugging — never commit.
/examples/Windows Screenreader Primer Fifth EditionChapter Files in Word/

# Throwaway UI prototype scratch (Table Studio / accessible CSV editor spikes) —
# not part of the shipped app and excluded from lint/type gates.
/docs/planning/test/
docs/planning/source/test/

# ElevenDesk reference clone (its own git repo) consulted for the §1.2 ElevenLabs
# integration spec — not QUILL source; excluded from the parent repo's lint gates.
/docs/planning/eleven-labs/

# ACB audio-pipeline reference (docs/planning/source) is retained for the
# translated-audio-export work, but its regenerated outputs, sample inputs, and
# run logs are never committed.
docs/planning/source/**/output_audio/
docs/planning/source/**/papers/
docs/planning/source/**/*.log

# External reference / sample material kept in the working folder but not part of
# QUILL source — never commit. "Code Samples to Innovate With" is a ~626 MB
# code-sample corpus (AI_TTS_Studio etc.); examples/audio holds large TTS test
# fixtures. (docs/prototypes, the Table Studio prototype scratch, was retired
# 2026-07-05 after the feature shipped; its one unharvested design note lives
# at docs/design/table-studio-macos-nsaccessibility.md.)
/Code Samples to Innovate With/
/examples/audio/
# Local Windows build output (portable bundle, zip, installer) -- multi-GB, regenerated.
/build-out/

# Podcast audio is distributed via the podcast-v1 GitHub release, not git.
docs/podcast/audio/

# Podcast Kokoro model files (~120 MB) staged locally for generation; never commit.
docs/podcast/tools/models/

# Compiled native extensions are per-machine build artifacts; only the C++
# sources and CMakeLists are tracked (quill/native/*). Built locally or in CI.
quill/native/**/*.pyd
