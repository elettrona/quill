#: quill/core/features.py:37
msgid "Essential"
msgstr "Essenziale"

#: quill/core/features.py:38
msgid "Core editing, file, and navigation features."
msgstr "Funzionalità principali di modifica, gestione dei file e navigazione."

#: quill/core/features.py:79
msgid "Casual Writer"
msgstr "Scrittore Occasionale"

#: quill/core/features.py:81
msgid ""
"Everyday writing, formatting, and cleanup with guided power features. For"
" papers, citations, and a table of contents, try the Author or Student "
"profile instead."
msgstr "Scrittura quotidiana, formattazione e correzione con funzioni avanzate e guidate. Se devi scrivere saggi, gestire citazioni o creare un sommario, prova invece il profilo Autore o Studente."

#: quill/core/features.py:105
msgid "Author or Student"
msgstr "Autore o Studente"

#: quill/core/features.py:107
msgid ""
"Long-form writing with a table of contents, footnotes, and MLA / Chicago "
"/ APA citations — for papers, theses, and class assignments. Choose your "
"citation style from Preferences > Profiles and Features."
msgstr "Scrittura di testi lunghi con sommario, note a piè di pagina e citazioni MLA / Chicago / APA — per saggi, tesi e tesine scolastiche. Scegli il tuo stile di citazione in Preferenze > Profili e funzionalità."

#: quill/core/features.py:133
msgid "Reader and Student"
msgstr "Lettore e Studente"

#: quill/core/features.py:134
msgid "Reading, highlights, references, and light writing workflows."
msgstr "Lettura, evidenziazioni, riferimenti e attività di scrittura leggera."

#: quill/core/features.py:153
msgid "Office and Admin"
msgstr "Ufficio e amministrazione"

#: quill/core/features.py:154
msgid "Reliable file work, sessions, cleanup, and printing."
msgstr "Gestione affidabile dei file, sessioni di lavoro, pulizia del testo e stampa."

#: quill/core/features.py:173
msgid "Developer and Power Text"
msgstr "Sviluppatore ed editing avanzato"

#: quill/core/features.py:175
msgid "Regular Expression, cleanup, inspection, and document analysis tools."
msgstr "Espressioni regolari, pulizia, ispezione, e strumenti di analisi documenti."

#: quill/core/features.py:194
msgid "Low Vision"
msgstr "Ipovisione"

#: quill/core/features.py:196
msgid "Higher contrast, larger reading aids, and friendly inspection tools."
msgstr "Contrasto elevato, strumenti di lettura ingrandita e funzioni semplificate di ispezione."

#: quill/core/features.py:216
msgid "Braille and Screen Reader Power User"
msgstr "Utente esperto di Braille e screen reader"

#: quill/core/features.py:218
msgid ""
"Screen-reader-friendly navigation with advanced text tools surfaced "
"calmly."
msgstr "Navigazione ottimizzata per  screen reader e strumenti di testo avanzati accessibili senza distrazioni."

#: quill/core/features.py:238
msgid "Accessibility Professional"
msgstr "Professionista dell'accessibilità"

#: quill/core/features.py:239
msgid "Reading, inspection, trust, and accessibility diagnostics."
msgstr "Lettura, ispezione, affidabilità, e diagnosi di accessibilità."

#: quill/core/features.py:258
msgid "Full Quill"
msgstr "Quill completo"

#: quill/core/features.py:259
msgid "Everything visible, including advanced and experimental paths."
msgstr "Tutto visibile, inclusi i percorsi avanzati e sperimentali."

#: quill/ui/ai_chat_dialog.py:32
msgid ""
"OpenRouter gives access to many models with one key.\n"
"Sign up at openrouter.ai, then paste your key above and click Save Key."
msgstr ""
"OpenRouter ti permette di accedere a molti modelli con un'unica chiave.\n"
"Registrati su openrouter.ai, poi incolla la tua API Key qui sopra e clicca su Salva chiave."

#: quill/ui/ai_chat_dialog.py:36
msgid ""
"OpenAI provides GPT-4o and other models.\n"
"Get your key from platform.openai.com under API keys.\n"
"Paste it above and click Save Key."
msgstr ""
"OpenAI fornisce GPT-4o e altri modelli.\n"
"Ottieni la tua chiave su platform.openai.com nella sezione Chiavi API.\n"
"Incollala qui sopra e clicca su Salva chiave."

#: quill/ui/ai_chat_dialog.py:41
msgid ""
"Ollama runs models locally — no key required.\n"
"Install from ollama.com and run: ollama serve\n"
"Then pull a model, e.g.: ollama pull gemma3:4b"
msgstr ""
"Ollama esegue i modelli in locale — non è richiesta alcuna chiave.\n" 
"Installa da ollama.com ed esegui: ollama serve \n" 
"Poi scarica un modello, ad esempio: ollama pull gemma3:4b"

#: quill/ui/ai_chat_dialog.py:46
msgid ""
"Ollama Cloud hosts large models remotely.\n"
"Sign up at ollama.com, get your API key,\n"
"then paste it above and click Save Key."
msgstr ""
"Ollama Cloud ospita modelli di grandi dimensioni da remoto.\n" 
"Registrati su ollama.com, ottieni la tua chiave API,\n" 
"Poi incollala qui sopra e clicca su Salva chiave."

